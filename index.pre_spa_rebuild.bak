membranous cataract, pars plana approach",5.96,90],["67031","Severing vitreous strands, pars plana approach",4.36,90],["67036","Vitrectomy, mechanical, pars plana approach",11.83,90],["67039","Vitrectomy, mechanical, pars plana approach; focal endolaser panretinal photocoagulation",12.87,90],["67040","Vitrectomy, mechanical, pars plana approach; endolaser panretinal photocoagulation",14.14,90],["67041","Vitrectomy, mechanical, pars plana approach; with removal of preretinal cellular membrane (macular pucker)",15.92,90],["67042","Vitrectomy, mechanical, pars plana approach; with removal of internal limiting membrane of retina",15.92,90],["67043","Vitrectomy, mechanical, pars plana approach; with removal of subretinal membrane",16.97,90],["67101","Repair retinal detachment; cryotherapy or diathermy",3.41,90],["67105","Repair retinal detachment; photocoagulation",3.31,90],["67107","Repair retinal detachment; scleral buckling",15.6,90],["67108","Repair retinal detachment; vitrectomy, any method, with or without air or gas tamponade",16.7,90],["67110","Repair retinal detachment; pneumatic retinopexy",9.99,90],["67113","Repair complex retinal detachment with vitrectomy and membrane peeling",18.53,90],["67115","Aspiration or release of subretinal/choroidal fluid, external approach",5.96,90],["67120","Removal of implanted material, posterior segment; intraocular",6.92,90],["67121","Removal of implanted material, posterior segment; extraocular",11.94,90],["67141","Prophylaxis of retinal detachment without drainage, one or more sessions; cryotherapy or diathermy",2.47,0]],"Anesthesiology":[["00100","Anesthesia for procedures on salivary glands",0.0,0],["00120","Anesthesia for procedures on external ear",0.0,0],["00140","Anesthesia for procedures on eye",0.0,0],["00142","Anesthesia for lens surgery",0.0,0],["00160","Anesthesia for procedures on nose and sinuses",0.0,0],["00170","Anesthesia for intraoral procedures",0.0,0],["00190","Anesthesia for procedures on facial bones",0.0,0],["00300","Anesthesia for procedures on head",0.0,0],["00320","Anesthesia for procedures on major vessels of neck",0.0,0],["00400","Anesthesia for procedures on integumentary system, anterior trunk",0.0,0],["00500","Anesthesia for esophageal procedures",0.0,0],["00520","Anesthesia for closed chest procedures",0.0,0],["00540","Anesthesia for thoracotomy, not otherwise specified",0.0,0],["00560","Anesthesia for cardiac procedures with pump oxygenator",0.0,0],["00600","Anesthesia for procedures on cervical spine",0.0,0],["00620","Anesthesia for procedures on thoracic spine",0.0,0],["00630","Anesthesia for procedures on lumbar spine",0.0,0],["00700","Anesthesia for procedures on upper anterior abdominal wall",0.0,0],["00790","Anesthesia for intraperitoneal upper abdominal procedures",0.0,0],["00800","Anesthesia for procedures on lower anterior abdominal wall",0.0,0],["00840","Anesthesia for intraperitoneal lower abdominal procedures",0.0,0],["00860","Anesthesia for renal procedures",0.0,0],["00880","Anesthesia for procedures on major abdominal blood vessels",0.0,0],["00902","Anesthesia for anorectal procedures",0.0,0],["00910","Anesthesia for transurethral procedures",0.0,0],["00940","Anesthesia for vaginal procedures",0.0,0],["01112","Anesthesia for bone marrow aspiration",0.0,0],["01200","Anesthesia for procedures on hip joint",0.0,0],["01210","Anesthesia for open hip procedures",0.0,0],["01214","Anesthesia for total hip replacement",0.0,0],["01400","Anesthesia for procedures on knee",0.0,0],["01402","Anesthesia for knee arthroplasty",0.0,0],["01480","Anesthesia for open procedures on lower leg/ankle/foot",0.0,0],["01630","Anesthesia for open shoulder procedures",0.0,0],["01710","Anesthesia for elbow procedures",0.0,0],["01810","Anesthesia for procedures on forearm/wrist/hand",0.0,0],["01920","Anesthesia for cardiac catheterization",0.0,0],["01924","Anesthesia for therapeutic interventional radiology",0.0,0],["01960","Anesthesia for vaginal delivery",0.0,0],["01961","Anesthesia for cesarean delivery",0.0,0],["01967","Epidural neuraxial analgesia for labor",0.0,0],["01968","Anesthesia for cesarean hysterectomy",0.0,0],["01990","Physiological support for organ harvesting",0.0,0]]};

// ===== STATE =====
let caseLines=[],audit=[],payer='medicare',setting='facility';
let nextLineId=1;

const NCCI={
 // "49593|15734": {modAllowed:true, note:"Component separation bundled with complex hernia repair; modifier 59 allowed when performed on separate anatomic site."},
 // "44970|44950": {modAllowed:false, note:"Appendectomy bundled; no modifier override permitted."},
};
function ncciCheck(cptA,cptB){return NCCI[`${cptA}|${cptB}`]||NCCI[`${cptB}|${cptA}`]||null}

const MOD_OPTS=[
 {v:'',code:'none',label:'No modifier',desc:'Separate procedure not claimed. Bundled or not distinct.'},
 {v:'59',code:'-59',label:'Distinct procedural service',desc:'General distinct-service marker. Medicare prefers X-modifiers when they apply.'},
 {v:'XS',code:'-XS',label:'Separate structure / site',desc:'Procedure performed on separate organ or anatomic site. Most common X-modifier for paired structures.'},
 {v:'XE',code:'-XE',label:'Separate encounter',desc:'Procedure performed in a separate operative session same day.'},
 {v:'XP',code:'-XP',label:'Separate practitioner',desc:'Procedure performed by a different practitioner.'},
 {v:'XU',code:'-XU',label:'Unusual non-overlapping service',desc:'Does not overlap usual components of the primary service.'}
];

function log(m){audit.unshift(`[${new Date().toLocaleTimeString()}] ${m}`)}
function isRoboticAllowed(cpt){return ROBOTIC_ALLOWED.includes(String(cpt))}
function getApproachMode(desc){return /^(thora|thoracoscopic|vats)/i.test(String(desc||''))?'thora':'lap'}
function formatProcDesc(cpt,desc){
 if(!isRoboticAllowed(cpt))return desc;
 if(getApproachMode(desc)==='thora')return desc.replace(/^(Thoracoscopic|VATS)\s+/i,'').trim().replace(/^(.+)$/,'Thora / Robotic $1');
 return desc.replace(/^Lap\s+/i,'Lap / Robotic ');
}
function getStoredApproach(cpt,desc){return getApproachMode(desc)}
function setApproach(si,pi,approach,e){
 if(e)e.stopPropagation();
 const row=document.getElementById(`p${si}-${pi}`);if(!row)return;
 row.dataset.approach=approach;
 row.querySelectorAll('.approach-chip').forEach(chip=>chip.classList.toggle('active',chip.dataset.v===approach));
}
function getRowApproach(si,pi,desc){
 const row=document.getElementById(`p${si}-${pi}`);
 return row?.dataset.approach||getStoredApproach(null,desc);
}

// ===== RENDER SPECIALTIES =====
let pickingFor=null;

function isMyofascialRelease(desc){
 const normalized=String(desc||'').replace(/^Lap \/ Robotic\s+/i,'').replace(/^Thora \/ Robotic\s+/i,'').trim();
 return /myofascial flap|retrorectus|\btar\b|transversus abdominis|component separation|posterior release|rectus myofascial release/i.test(normalized);
}

function renderSpecs(){
 const c=document.getElementById('specs');
 const specialtyNotes={
  'Vascular Surgery':'<div class="spec-note"><strong>Duplicate-code note:</strong> Some vascular and endovascular CPT codes may also appear under <strong>Interventional Radiology</strong>. If a duplicate or expected vascular code is not obvious here, check both sections.</div>',
  'Interventional Radiology':'<div class="spec-note"><strong>Duplicate-code note:</strong> Some endovascular, access, and vascular-related CPT codes may also appear under <strong>Vascular Surgery</strong>. For duplicate or hard-to-locate codes, check both sections.</div>'
 };
 c.innerHTML=Object.entries(SPECS).map(([name,procs],si)=>`
  <div class="spec" id="sp${si}">
   <div class="spec-t" onclick="toggleSpec(${si})"><div class="spec-n">${name}</div><div class="spec-c">›</div></div>
   <div class="spec-body">${specialtyNotes[name]||''}${procs.map((p,pi)=>{
    const [cpt,desc,w,bi]=p;
    const biVal=isMyofascialRelease(desc)?1:((bi===0||bi===1||bi===2)?bi:0);
    const approachMode=getApproachMode(desc);
    const hasApproach=isRoboticAllowed(cpt);
    const displayDesc=formatProcDesc(cpt,desc);
    const biClass=biVal===1?'has-lat':'';
    const biLabel=biVal===2?'<span class=\"proc-bi\">inh-bilat</span>':'';
    const wNum=typeof w==='number'?w:Number(w||0);
    const meta=(searchState.codeMeta&&searchState.codeMeta[String(cpt)])||null;
    const warnChip='';
    const approachTray=hasApproach?`<div class=\"approach-tray\">
      <span class=\"lat-lbl\">Approach</span>
      <button class=\"lat-chip approach-chip active\" data-v=\"${approachMode}\" onclick=\"setApproach(${si},${pi},'${approachMode}',event)\">${approachMode==='thora'?'Thora':'Lap'}</button>
      <button class=\"lat-chip approach-chip\" data-v=\"robotic\" onclick=\"setApproach(${si},${pi},'robotic',event)\">Robotic</button>
     </div>`:'';
    return `<div class=\"proc ${biClass}\" id=\"p${si}-${pi}\" data-approach=\"${approachMode}\" onclick=\"onProcClick(${si},${pi},event)\">
     <div class=\"proc-n\">${displayDesc}${warnChip}${biLabel}</div>
     <div class=\"proc-c\">${cpt}</div>
     <div class=\"proc-w\">${wNum.toFixed(2)}</div>
     ${biVal===1?`<div class=\"lat-tray\">${approachTray}
      <span class=\"lat-lbl\">Laterality</span>
      <button class=\"lat-chip\" onclick=\"commitLat('${cpt}',${JSON.stringify(desc).replace(/\"/g,'&quot;')},${w},'RT',event)\">Right <span class=\"k\">R</span></button>
      <button class=\"lat-chip\" onclick=\"commitLat('${cpt}',${JSON.stringify(desc).replace(/\"/g,'&quot;')},${w},'LT',event)\">Left <span class=\"k\">L</span></button>
      <button class=\"lat-chip\" onclick=\"commitLat('${cpt}',${JSON.stringify(desc).replace(/\"/g,'&quot;')},${w},'50',event)\">Bilateral <span class=\"k\">B</span></button>
      <button class=\"lat-cancel\" onclick=\"cancelLat(event)\">cancel <span class=\"k\" style=\"border:1px solid currentColor;padding:0 3px;border-radius:2px;margin-left:2px\">esc</span></button>
     </div>`:`${approachTray}`}
     <div class=\"bi-note\" id=\"note-${si}-${pi}\">inherently bilateral · no -50 needed</div>
    </div>`;
   }).join('')}</div>
  </div>`).join('');
}
function toggleSpec(i){document.getElementById('sp'+i).classList.toggle('open')}

function onProcClick(si,pi,e){
 if(e&&(e.target.closest('.lat-tray')||e.target.closest('.approach-tray')))return;
 const [cpt,desc,w,bi]=SPECS[Object.keys(SPECS)[si]][pi];
 const biVal=isMyofascialRelease(desc)?1:((bi===0||bi===1||bi===2)?bi:0);
 const approach=isRoboticAllowed(cpt)?getRowApproach(si,pi,desc):undefined;
 if(biVal===0){addProc(cpt,desc,w,'',0,approach);return}
 if(biVal===2){
  addProc(cpt,desc,w,'',2,approach);
  const n=document.getElementById(`note-${si}-${pi}`);
  n.classList.add('show');setTimeout(()=>n.classList.remove('show'),2000);
  return;
 }
 if(pickingFor)cancelLat();
 const row=document.getElementById(`p${si}-${pi}`);
 row.classList.add('picking');
 pickingFor={si,pi,row};
}

function cancelLat(e){
 if(e)e.stopPropagation();
 if(pickingFor){pickingFor.row.classList.remove('picking');pickingFor=null}
}

function commitLat(cpt,desc,w,lat,e){
 if(e)e.stopPropagation();
 const row=e?.target?.closest('.proc');
 const approach=isRoboticAllowed(cpt)?(row?.dataset.approach||getStoredApproach(cpt,desc)):undefined;
 addProc(cpt,desc,w,lat,1,approach);
 cancelLat();
}

document.addEventListener('keydown',e=>{
 if(!pickingFor)return;
 if(document.activeElement.tagName==='INPUT')return;
 const k=e.key.toLowerCase();
 if(k==='escape'){cancelLat();e.preventDefault();return}
 const {si,pi}=pickingFor;
 const [cpt,desc,w]=SPECS[Object.keys(SPECS)[si]][pi];
 if(k==='r'){commitLat(cpt,desc,w,'RT');e.preventDefault()}
 if(k==='l'){commitLat(cpt,desc,w,'LT');e.preventDefault()}
 if(k==='b'){commitLat(cpt,desc,w,'50');e.preventDefault()}
});

// ===== ADD HANDLERS =====
function addProc(cpt,desc,wrvu,laterality,bi,approach,dx,meta){
 const existing=caseLines.filter(l=>l.kind==='proc'&&l.cpt===cpt);
 const lateralToken=String(laterality||'').toUpperCase();
 const normalizedDesc=String(desc||'');
 const inferredMidline=/\b(ventral|umbilical|epigastric|incisional|abdominal wall|midline)\b/i.test(normalizedDesc);
 const line={id:nextLineId++,cpt,desc,baseWrvu:wrvu,laterality:lateralToken,biIndicator:bi||0,kind:'proc',mods:[],userMod:'',isMidline:inferredMidline};
 if(meta&&typeof meta==='object')Object.assign(line,meta);
 if(dx&&dx.length)line.dx=[...dx];
 if(approach)line.approach=approach;
 if(existing.length>0){
  caseLines.push(line);
  log(`ADD ${cpt} "${desc}" [REPEAT #${existing.length+1}] — modifier picker opened`);
  recalc('repeat procedure added');
  openMpick(line.id,{suggestion:'XS',reason:`This is instance ${existing.length+1} of ${cpt}. For a procedure performed on a separate anatomic site (for example contralateral component separation or multiple graft sites), use -XS. For a genuinely separate operative session, use -XE. -59 is the general fallback.`});
  return;
 }
 caseLines.push(line);
 const latStr=laterality==='50'?'BILATERAL':(laterality||'');
 log(`ADD ${cpt} "${desc}"${latStr?' ['+latStr+']':''} wRVU=${wrvu}`);
 recalc('procedure added');
}
function addEM(cpt,desc,wrvu,meta){
 const line={cpt,desc,baseWrvu:wrvu,kind:'em',mods:[]};
 if(meta&&typeof meta==='object')Object.assign(line,meta);
 caseLines.push(line);
 log(`ADD E/M ${cpt} "${desc}" wRVU=${wrvu}`);
 recalc('E/M added');
}
function removeLine(i){log(`REMOVE ${caseLines[i].cpt}`);caseLines.splice(i,1);recalc('line removed')}
function clearCase(){caseLines=[];log('CASE CLEARED');recalc('cleared')}

function isAddonCode(cpt){return ['49568'].includes(String(cpt||''))}
function isMajorSurgeryCode(cpt){return /^49|^15|^31/.test(String(cpt||''))}
function getModifierConflictState(){
 if(caseLines.some(l=>l.engineState==='BLOCKED'))return 'BLOCKED';
 if(caseLines.some(l=>l.engineState==='WARNING'))return 'WARNING';
 return 'CLEAN';
}

// ===== MODIFIER ENGINE =====
function computeMods(){
 const procs=caseLines.filter(l=>l.kind==='proc').sort((a,b)=>b.baseWrvu-a.baseWrvu);
 const ems=caseLines.filter(l=>l.kind==='em');
 caseLines=[...procs,...ems];
 const hasRepeated15734=procs.filter(l=>l.cpt==='15734').length>1;
 let pIdx=0;
 let repeated15734Rank=0;
 caseLines.forEach(l=>{
  l.mods=[];l.rationale=[];
  l.warnings=[];
  l.conflicts=[];
  l.engineState='CLEAN';
  if(l.kind==='em'){
   if(procs.length>0){
    const major=procs.some(p=>isMajorSurgeryCode(p.cpt));
    if(major&&l.userMod==='25'){
     l.conflicts.push('Modifier -25 conflicts with same-day major surgery decision context; use -57 when decision for major surgery is documented.');
     l.userMod='57';
    }
    if(l.userMod==='57'||major){l.mods.push('57');l.engineState='WARNING';l.rationale.push({mod:'57',reason:`E/M on same day as major surgery decision. Modifier 57 used instead of -25 when the evaluation resulted in the decision for surgery.`,cite:RULES.MOD_57})}
    else{l.mods.push('25');l.rationale.push({mod:'25',reason:`E/M billed same session as ${procs[0].cpt}. Modifier 25 required.`,cite:RULES.MOD_25})}
   }
   l.effWrvu=l.baseWrvu;l.rank='E/M';l.rankReason='Evaluation & management service.';return;
  }
  const descText=String(l.desc||'');
  const inferredSide=/\bright\b/i.test(descText)?'RT':(/\bleft\b/i.test(descText)?'LT':'');
  const isMidline=l.isMidline||/\b(ventral|umbilical|epigastric|incisional|abdominal wall|midline)\b/i.test(descText);
  if(!l.laterality&&l.biIndicator===1&&inferredSide)l.laterality=inferredSide;
  if(isMidline&&(l.laterality==='RT'||l.laterality==='LT'||l.laterality==='50')){
   l.warnings.push('Midline structure detected. Removed invalid laterality modifier.');
   l.rationale.push({mod:'Warning',reason:'Midline / non-lateral structure. RT, LT, and -50 are suppressed unless CPT rules explicitly allow them.',cite:RULES.MIDLINE});
   l.laterality='';
  }
  if((l.laterality==='RT'||l.laterality==='LT')&&String(l.userMod||'').toUpperCase()==='50'){
   l.conflicts.push('Blocked conflicting use of -50 with RT/LT on the same line.');
  }
  if(l.laterality==='50'){
   const bilateralEligible=l.biIndicator===1||/\btrue bilateral same procedure\b/i.test(descText);
   if(!bilateralEligible||/\b(inherently bilateral)\b/i.test(descText)){
    l.conflicts.push('Blocked invalid bilateral modifier. Code/case structure does not support defensible use of -50.');
   }else{
    l.mods.push('50');
    l.effWrvu=l.baseWrvu*1.5;
    l.rationale.push({mod:'50',reason:'True bilateral same procedure. Default billing uses -50 with 150% valuation.',cite:RULES.MOD_50});
    if(l.cpt==='15734'||payer==='commercial'){l.engineState='WARNING';l.rationale.push({mod:'Alt',reason:'Default: -50. Some payers require RT/LT split billing.',cite:RULES.MOD_50_ALT});}
   }
  }
  else if(l.laterality==='RT'||l.laterality==='LT'){
   l.mods.push(l.laterality);
   l.effWrvu=l.baseWrvu;
   l.rationale.push({mod:l.laterality,reason:`${l.laterality==='RT'?'Right':'Left'}-side anatomic modifier appended for unilateral or side-specific procedure.`,cite:RULES.MOD_RT_LT});
  }
  else l.effWrvu=l.baseWrvu;
  if(l.approach==='robotic'){
   const roboticReason=getApproachMode(l.desc)==='thora'
    ? 'Performed robotically — coded as thoracoscopically per CMS/AMA guidance; robotic assistance documented for clinical record, does not affect CPT selection or reimbursement.'
    : 'Performed robotically — coded as laparoscopic per CMS/AMA guidance; robotic assistance documented for clinical record, does not affect CPT selection or reimbursement.';
   l.rationale.push({mod:'—',reason:roboticReason,cite:'CMS/AMA robotic coding guidance'});
  }
  const primaryProc=procs[0];
  const pairEdit=pIdx>0?ncciCheck(primaryProc?.cpt,l.cpt):null;
  if(pairEdit&&pairEdit.note&&pairEdit.modAllowed&&(l.laterality==='RT'||l.laterality==='LT')&&(primaryProc?.laterality===l.laterality)){
   l.conflicts.push('Conditional NCCI pair remains conflicted because both procedures are on the same side. Laterality alone does not establish distinctness.');
  }
  if(isAddonCode(l.cpt)&&pIdx===0){
   l.conflicts.push('Add-on code cannot be ranked as primary. Parent/base code required.');
  }
  if(pIdx===0){
   l.rank=isAddonCode(l.cpt)?'Add-on':'Primary';l.rankReason=`Highest wRVU (${l.effWrvu.toFixed(2)}). Billed 100%.`;
   l.rationale.unshift({mod:'Rank',reason:isAddonCode(l.cpt)?'Add-on code detected. Primary ranking blocked until parent code is present.':'Primary procedure — no MPPR reduction.',cite:RULES.PRIMARY});
  }else{
   l.rank=`Secondary #${pIdx}`;
   l.rankReason=`Secondary procedure, ranked below primary ${procs[0].cpt}.`;
   if(hasRepeated15734&&l.cpt==='15734'&&payer!=='commercial'){
    repeated15734Rank++;
    const factor=repeated15734Rank<=2?0.5:0.25;
    l.effWrvu=l.baseWrvu*factor;
    l.rationale.push({mod:'Rank',reason:`Repeated 15734 component separation ranked at ${factor===0.5?'50%':'25%'} per current site rule for multiple myofascial releases.`,cite:'FreeCPTCodeFinder component separation rule'});
   }else if(payer==='commercial'){l.mods.push('51');l.rationale.push({mod:'51',reason:'Commercial payer multi-procedure marker.',cite:RULES.MOD_51})}
   else l.rationale.push({mod:'Rank',reason:'Medicare MPPR applied automatically; -51 omitted.',cite:RULES.MPPR});
   if(l.userMod){
    const edit=pairEdit;
    if(l.userMod==='59'&&!edit){l.conflicts.push('Modifier -59 blocked because no NCCI conditional edit exists for this code pair.');}
    else if(l.userMod==='59'&&(l.laterality==='RT'||l.laterality==='LT')){l.conflicts.push('Modifier -59 blocked because RT/LT laterality already resolves distinctness.');}
    else if(edit&&!edit.modAllowed){l.conflicts.push('Fully bundled pair is non-payable. Modifier cannot rescue payment.');}
    else if(isAddonCode(l.cpt)){l.conflicts.push('Distinct service modifier blocked on add-on code without explicit CPT support.');}
    else{
     l.mods.push(l.userMod);
     const opt=MOD_OPTS.find(o=>o.v===l.userMod);
     l.rationale.push({mod:l.userMod,reason:`Coder-affirmed: ${opt.label}. ${opt.desc} Documentation must support this selection.`,cite:RULES.MOD_59});
     if(l.userMod==='59'||String(l.userMod||'').startsWith('X'))l.engineState='WARNING';
    }
   }else{
    l.rationale.push({mod:'—',reason:'No distinct-service modifier applied. If this procedure is on a separate site or encounter from the primary, coder should review and add -59, -XS, -XE, -XP, or -XU via the line editor.',cite:RULES.MOD_59});
   }
  }
  if(l.conflicts.length){
   l.engineState='BLOCKED';
   l.warnings.push(...l.conflicts);
   l.mods=[];
   l.rationale.push({mod:'Blocked',reason:l.conflicts.join(' '),cite:RULES.CONFLICT});
  }
  pIdx++;
 });
 log(`RECALC primary=${procs[0] ? procs[0].cpt : '—'} · ${procs.length} proc + ${ems.length} E/M · ${payer} · state=${getModifierConflictState()}`);
}

let mpickLineId=null,mpickIndex=0;

function openMpick(lineId,opts={}){
 const line=caseLines.find(l=>l.id===lineId);if(!line)return;
 mpickLineId=lineId;
 document.getElementById('mpick-title').textContent=`${line.cpt} · ${line.desc}`;
 document.getElementById('mpick-sub').textContent=`Select distinct-service modifier`;
 const primary=caseLines.filter(l=>l.kind==='proc')[0];
 const ncciEl=document.getElementById('mpick-ncci');
 if(primary&&primary.cpt!==line.cpt){
  const edit=ncciCheck(primary.cpt,line.cpt);
  if(edit){ncciEl.textContent=`NCCI edit: ${edit.note}`;ncciEl.classList.add('show')}
  else{ncciEl.classList.remove('show')}
 }else ncciEl.classList.remove('show');
 if(opts.reason){
  const w=document.getElementById('mpick-warn');
  w.innerHTML=opts.reason+'<br><br>Documentation must support the selection before submission.';
 }
 const suggestion=opts.suggestion||line.userMod||'';
 const optsEl=document.getElementById('mpick-opts');
 optsEl.innerHTML=MOD_OPTS.map((o,i)=>`
  <button class="mpick-opt ${o.v===''?'none':''} ${o.v===suggestion?'hl':''}" data-i="${i}" data-v="${o.v}" onclick="commitMpick('${o.v}')">
   <div class="mk">${o.code}</div>
   <div><div class="ml">${o.label}</div><div class="md">${o.desc}</div></div>
  </button>`).join('');
 mpickIndex=Math.max(0,MOD_OPTS.findIndex(o=>o.v===suggestion));
 updateMpickHL();
 document.getElementById('mpick').classList.add('open');
}

function updateMpickHL(){
 document.querySelectorAll('.mpick-opt').forEach((el,i)=>el.classList.toggle('hl',i===mpickIndex));
}
function commitMpick(v){
 const line=caseLines.find(l=>l.id===mpickLineId);if(!line){closeMpick();return}
 line.userMod=v;
 log(`MODIFIER SET ${line.cpt} → ${v?'-'+v:'none'} (coder affirmed)`);
 closeMpick();
 recalc('modifier set');
}
function closeMpick(){document.getElementById('mpick').classList.remove('open');mpickLineId=null}

document.addEventListener('keydown',e=>{
 if(!document.getElementById('mpick').classList.contains('open'))return;
 if(e.key==='Escape'){closeMpick();e.preventDefault()}
 if(e.key==='ArrowDown'){mpickIndex=Math.min(MOD_OPTS.length-1,mpickIndex+1);updateMpickHL();e.preventDefault()}
 if(e.key==='ArrowUp'){mpickIndex=Math.max(0,mpickIndex-1);updateMpickHL();e.preventDefault()}
 if(e.key==='Enter'){commitMpick(MOD_OPTS[mpickIndex].v);e.preventDefault()}
});

function renderDxList(){
 const el=document.getElementById('dxs');
 if(!el)return;
 const dx=[...new Set(caseLines.flatMap(l=>(Array.isArray(l.dx)&&l.dx.length?l.dx:(DX_BY_CPT[String(l.cpt||'')]||[]))))];
 if(!dx.length){
  el.innerHTML='<div class="lns-empty">Select a surgery to surface diagnosis codes.</div>';
  return;
 }
 el.innerHTML=dx.map(code=>`<div class="rl"><div class="rlt"><span class="rcpt">${code}</span></div></div>`).join('');
}

function recalc(why){
 if(caseLines.length)computeMods();
 let twrvu=0,rank=0;
 caseLines.forEach(l=>{
  twrvu+=l.effWrvu;
  const base=l.effWrvu*CF;
  if(l.kind==='em'){l.pay=base}
  else{l.pay=(rank===0||setting==='nonfac')?base:base*0.5;rank++}
 });
 const tpay=caseLines.reduce((s,l)=>s+l.pay,0);
 const lns=document.getElementById('lns');
 if(!caseLines.length){lns.innerHTML='<div class="lns-empty">Click any procedure or code to add it here. The system will auto-assign primary/secondary and apply modifiers.</div>'}
 else{
  let rk=0;
  lns.innerHTML=caseLines.map((l,i)=>{
   let label;
   if(l.kind==='em'){label='<span class="rk em">E/M</span>'}
   else{label=`<span class="rk ${rk===0?'p':''}">${rk===0?'Primary':'Sec '+rk}</span>`;rk++}
   return `<div class="rl">
    <div class="rlt">${label}<span class="rcpt">${l.cpt}</span>${l.mods.length?`<span class="rmd">-${l.mods.join('-')}</span>`:''}${l.kind==='proc'&&rk>1?`<span class="mod-edit" onclick="event.stopPropagation();openMpick(${l.id})">edit</span>`:''}<span class="rx" onclick="removeLine(${i})">×</span></div>
    <div class="rd">${l.desc}${l.approach?` · ${l.approach==='robotic'?'Robotic':(l.approach==='thora'?'Thora':'Lap')}`:''}</div>
    <div class="rw"><span class="rwl">wRVU ${l.effWrvu.toFixed(2)}</span><span>$${l.pay.toFixed(2)}</span></div>
    ${l.warnings&&l.warnings.length?`<div class="md" style="margin-top:6px;color:#92400e">${l.warnings.join(' ')}</div>`:''}
   </div>`}).join('');
 }
 document.getElementById('tn').textContent=twrvu.toFixed(2);
 const mppr=caseLines.filter(l=>l.kind==='proc').length>1&&setting==='facility';
 document.getElementById('ts').textContent=`$${tpay.toFixed(2)}${mppr?' · MPPR applied':''}`;
 document.getElementById('rm').textContent=`${caseLines.length} line${caseLines.length!==1?'s':''} · ${payer} · ${getModifierConflictState()}`;
 renderDxList();
 log(`TOTALS wRVU=${twrvu.toFixed(2)} pay=$${tpay.toFixed(2)} (${why})`);
}

// ===== SEGMENTED CONTROLS =====
document.querySelectorAll('.seg').forEach(seg=>{
 seg.querySelectorAll('button').forEach(b=>b.onclick=()=>{
  seg.querySelectorAll('button').forEach(x=>x.classList.remove('on'));
  b.classList.add('on');
  if(seg.id==='payer-seg')payer=b.dataset.v;
  if(seg.id==='setting-seg')setting=b.dataset.v;
  recalc(seg.id.replace('-seg','')+' changed');
 });
});

const RULES={
 PRIMARY:"CMS Pub. 100-04, Ch. 12 §40.6.B — highest wRVU procedure billed at 100%",
 MOD_59:"CMS NCCI Policy Manual Ch. 1 §E — modifier 59 indicates distinct procedural service when procedures would otherwise be bundled",
 MOD_51:"CPT 2026 Appendix A — modifier 51 identifies secondary procedures when multiple procedures performed same session (commercial payers only; Medicare uses MPPR)",
 MOD_25:"CPT 2026 Appendix A — modifier 25 indicates significant, separately identifiable E/M on same day as a procedure",
 MOD_57:"CPT 2026 Appendix A — modifier 57 indicates the decision for major surgery was made during the E/M service",
 MOD_50:"CPT 2026 Appendix A — modifier 50 for bilateral procedures; paid at 150% of base",
 MOD_RT_LT:"HCPCS Level II — anatomic laterality modifiers",
 MOD_50_ALT:"Payer variation note — some payers require bilateral split billing with RT/LT instead of modifier 50",
 MIDLINE:"Midline/non-lateral structures should not receive RT, LT, or -50 unless CPT-specific guidance explicitly permits it",
 CONFLICT:"FreeCPT modifier conflict engine — invalid modifier structures are blocked until corrected",
 MPPR:"CMS Physician Fee Schedule — Multiple Procedure Payment Reduction: primary paid 100%, secondary procedures paid 50% in facility setting",
 CF_2026:"CMS 2026 Physician Fee Schedule Final Rule — national conversion factor $32.3465"
};

function openAuditReport(){
 if(!caseLines.length){alert('Add procedures to the case first.');return}
 const now=new Date();
 const caseId='CASE-'+now.getFullYear()+String(now.getMonth()+1).padStart(2,'0')+String(now.getDate()).padStart(2,'0')+'-'+Math.random().toString(36).slice(2,6).toUpperCase();
 let totalWrvu=0,totalPay=0;
 caseLines.forEach(l=>{totalWrvu+=l.effWrvu;totalPay+=l.pay});

 const rows=caseLines.map((l,i)=>{
  const rationaleHTML=l.rationale.map(r=>`
   <div class="rationale-item">
    <div class="rationale-mod">${r.mod==='—'?'Ranking':'Modifier -'+r.mod}</div>
    <div class="rationale-text">${r.reason}</div>
    <div class="rationale-cite">${r.cite}</div>
   </div>`).join('');
  return `
  <tr class="line-row">
   <td class="num">${i+1}</td>
   <td class="rank-cell"><span class="rank-badge ${l.rank==='Primary'?'p':l.kind==='em'?'em':'s'}">${l.rank}</span></td>
   <td class="cpt-cell">${l.cpt}${l.mods.length?'<span class="mod-tag">-'+l.mods.join('-')+'</span>':''}</td>
   <td class="desc-cell">${l.desc}</td>
   <td class="num mono">${l.effWrvu.toFixed(2)}</td>
   <td class="num mono">$${l.pay.toFixed(2)}</td>
  </tr>
  <tr class="rationale-row"><td></td><td colspan="5">
   <div class="rank-reason"><strong>Ranking basis:</strong> ${l.rankReason}</div>
   ${rationaleHTML}
  </td></tr>`;
 }).join('');

 const html=`<!doctype html><html><head><meta charset="utf-8"><title>${caseId} — Coding Audit Report</title>
<style>
@page{size:letter;margin:0.6in}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,Segoe UI,Roboto,sans-serif;font-size:11pt;line-height:1.5;color:#0a0a0a;background:#fff;padding:40px;max-width:8.5in;margin:auto}
.header{border-bottom:2px solid #6E1919;padding-bottom:14px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:flex-start}
.header h1{font-size:18pt;font-weight:600;letter-spacing:-.01em;color:#6E1919}
.header .sub{font-size:10pt;color:#52525B;margin-top:2px}
.header .meta{text-align:right;font-size:9pt;color:#52525B;font-family:ui-monospace,Menlo,monospace;line-height:1.7}
.summary{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid #E4E4E0;border-radius:6px;margin-bottom:22px}
.summary>div{padding:12px 14px;border-right:1px solid #E4E4E0}
.summary>div:last-child{border-right:0}
.summary .lbl{font-size:8pt;text-transform:uppercase;letter-spacing:.08em;color:#9A9A94;margin-bottom:4px;font-weight:600}
.summary .val{font-size:14pt;font-weight:500;font-family:ui-monospace,monospace}
.summary .val.money{color:#2D5A3D}
h2{font-size:11pt;text-transform:uppercase;letter-spacing:.1em;color:#9A9A94;margin:22px 0 10px;font-weight:600}
table{width:100%;border-collapse:collapse;font-size:10pt}
.line-row td{padding:10px 8px;border-top:1px solid #E4E4E0;vertical-align:top}
.line-row .num{text-align:right;color:#9A9A94;font-family:ui-monospace,monospace;width:28px}
.line-row .rank-cell{width:80px}
.line-row .cpt-cell{width:130px;font-family:ui-monospace,monospace;font-weight:500}
.line-row .mono{font-family:ui-monospace,monospace;width:60px}
.rank-badge{display:inline-block;font-size:8pt;font-weight:600;text-transform:uppercase;letter-spacing:.06em;padding:2px 7px;border:1px solid #CFCCC0;border-radius:3px;color:#52525B}
.rank-badge.p{color:#6E1919;border-color:#6E1919;background:#F4EBEB}
.rank-badge.em{color:#2D5A3D;border-color:#2D5A3D;background:#EAF3ED}
.rank-badge.s{color:#52525B}
.mod-tag{font-family:ui-monospace,monospace;color:#6E1919;font-weight:500;margin-left:4px;font-size:9pt}
.rationale-row td{padding:4px 8px 14px;border-top:0;background:#FAFAF7}
.rank-reason{font-size:9.5pt;color:#0a0a0a;margin-bottom:8px;padding:8px 10px;background:#fff;border-left:3px solid #6E1919}
.rationale-item{padding:6px 10px;margin-top:4px;background:#fff;border:1px solid #E4E4E0;border-radius:4px;font-size:9pt}
.rationale-mod{font-weight:600;color:#6E1919;font-size:8.5pt;text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.rationale-text{color:#0a0a0a;margin-bottom:4px}
.rationale-cite{font-size:8pt;color:#9A9A94;font-style:italic;font-family:ui-monospace,monospace}
.totals{margin-top:20px;padding:14px 16px;background:#FAFAF7;border:1px solid #E4E4E0;border-radius:6px;display:flex;justify-content:space-between;align-items:center}
.totals .left{font-size:10pt;color:#52525B}
.totals .right{font-size:16pt;font-weight:500;font-family:ui-monospace,monospace}
.totals .right .money{color:#2D5A3D}
.footer{margin-top:28px;padding-top:14px;border-top:1px solid #E4E4E0;font-size:8pt;color:#9A9A94;line-height:1.6}
.footer strong{color:#52525B}
.sig{margin-top:30px;display:grid;grid-template-columns:1fr 1fr;gap:40px}
.sig-line{border-top:1px solid #0a0a0a;padding-top:6px;font-size:8.5pt;color:#52525B}
.print-btn{position:fixed;top:14px;right:14px;background:#6E1919;color:#fff;border:0;padding:10px 18px;border-radius:5px;font-size:11pt;font-weight:500;cursor:pointer}
@media print{.print-btn{display:none}}
</style></head><body>

<button class="print-btn" onclick="window.print()">Print / Save as PDF</button>

<div class="header">
<div>
<h1>Surgical Coding Audit Report</h1>
<div class="sub">Case rationale and modifier justification — prepared for medical billing review</div>
</div>
<div class="meta">
<div><strong>${caseId}</strong></div>
<div>${now.toLocaleDateString()} ${now.toLocaleTimeString()}</div>
<div>FreeCPTCodeFinder</div>
</div>
</div>

<div class="summary">
<div><div class="lbl">Payer</div><div class="val">${payer}</div></div>
<div><div class="lbl">Setting</div><div class="val">${setting==='nonfac'?'Non-facility':'Facility'}</div></div>
<div><div class="lbl">Total wRVU</div><div class="val">${totalWrvu.toFixed(2)}</div></div>
<div><div class="lbl">Est. payment</div><div class="val money">$${totalPay.toFixed(2)}</div></div>
</div>

<h2>Line items with coding rationale</h2>
<table>
<tr style="font-size:8.5pt;color:#9A9A94;text-transform:uppercase;letter-spacing:.06em">
<td></td><td>Rank</td><td>CPT / modifiers</td><td>Description</td><td style="text-align:right">wRVU</td><td style="text-align:right">Payment</td>
</tr>
${rows}
</table>

<div class="totals">
<div class="left">Case totals · ${caseLines.length} line${caseLines.length!==1?'s':''} · ${caseLines.filter(l=>l.kind==='proc').length} procedure${caseLines.filter(l=>l.kind==='proc').length!==1?'s':''}${caseLines.filter(l=>l.kind==='em').length?' · '+caseLines.filter(l=>l.kind==='em').length+' E/M':''}</div>
<div class="right">${totalWrvu.toFixed(2)} wRVU · <span class="money">$${totalPay.toFixed(2)}</span></div>
</div>

<h2>Activity log</h2>
<div style="font-family:ui-monospace,monospace;font-size:8.5pt;color:#52525B;background:#FAFAF7;border:1px solid #E4E4E0;border-radius:4px;padding:12px;line-height:1.6;white-space:pre-wrap">${audit.slice().reverse().join('\n')||'No activity recorded.'}</div>

<div class="sig">
<div class="sig-line">Coder signature &nbsp;·&nbsp; date</div>
<div class="sig-line">Provider signature &nbsp;·&nbsp; date</div>
</div>

<div class="footer">
<p><strong>Regulatory basis:</strong> This report reflects coding logic applied per current CMS and AMA guidelines. Conversion factor ${CF} per ${RULES.CF_2026}. MPPR reductions applied per ${RULES.MPPR}.</p>
<p style="margin-top:8px"><strong>Disclaimer:</strong> This audit is a coding support document, not a substitute for professional medical coder review. All codes and modifiers should be verified against current AMA CPT Professional Edition, CMS Physician Fee Schedule, and NCCI edit files before claim submission. Rationale reflects automated rule application based on wRVU ranking, payer, and setting, coder must confirm that documentation supports each modifier, particularly modifier 59 (distinct procedural service).</p>
<p style="margin-top:8px"><strong>Not for submission without coder review.</strong> CPT® © American Medical Association. All rights reserved.</p>
</div>

</body></html>`;

 const w=window.open('','_blank');
 w.document.write(html);
 w.document.close();
 log(`AUDIT REPORT generated · ${caseId}`);
}

function exportAuditJSON(){
 if(!caseLines.length){alert('Add procedures to the case first.');return}
 const now=new Date();
 const report={
  caseId:'CASE-'+now.getFullYear()+String(now.getMonth()+1).padStart(2,'0')+String(now.getDate()).padStart(2,'0')+'-'+Math.random().toString(36).slice(2,6).toUpperCase(),
  generatedAt:now.toISOString(),
  conversionFactor:CF,
  cmsQuarter:'2026',
  payer,setting,
  totals:{
   wrvu:+(caseLines.reduce((s,l)=>s+l.effWrvu,0).toFixed(2)),
   payment:+(caseLines.reduce((s,l)=>s+l.pay,0).toFixed(2)),
   lines:caseLines.length,
   procedures:caseLines.filter(l=>l.kind==='proc').length,
   em:caseLines.filter(l=>l.kind==='em').length
  },
  lines:caseLines.map((l,i)=>({
   order:i+1,
   cpt:l.cpt,
   description:l.desc,
   rank:l.rank,
   rankReason:l.rankReason,
   modifiers:l.mods,
   baseWrvu:l.baseWrvu,
   effectiveWrvu:+l.effWrvu.toFixed(2),
   payment:+l.pay.toFixed(2),
   rationale:l.rationale
  })),
  activityLog:audit.slice().reverse(),
  disclaimer:'Automated coding support. Requires coder review prior to claim submission. CPT © AMA.'
 };
 const b=new Blob([JSON.stringify(report,null,2)],{type:'application/json'});
 const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=report.caseId+'.json';a.click();
 log(`AUDIT JSON exported · ${report.caseId}`);
}

// ===== SEARCH =====
const GUIDED_WORKFLOWS=[
 {id:'ventralHernia',title:'Ventral / Incisional Hernia',desc:'Size, approach, reducible vs incarcerated, myofascial release, rectus vs TAR, laterality',kind:'ventral-hernia'},
 {id:'umbilicalHernia',title:'Umbilical Hernia',desc:'Age/complexity plus myofascial release, rectus vs TAR, laterality',kind:'umbilical-hernia'},
 {id:'softTissue',title:'Soft Tissue Lesions / Lipoma / Cyst',desc:'Location, lesion family, size-based guided selection',kind:'soft-tissue'},
 {id:'pdCatheter',title:'Peritoneal Dialysis Catheter',desc:'Placement or removal with diagnosis suggestions',kind:'pd-catheter'}
];
let guidedState={kind:null,step:0,data:{}};

const searchState={
 specialtyFilter:'',
 searchResults:[],
 searchQuery:'',
 cptSearchIndex:[],
 codeMeta:{},
 activeResultIndex:-1,
 suppressTypeahead:false
};

function normalizeSearchValue(value){
 return String(value||'').toLowerCase().replace(/[^a-z0-9]+/g,' ').trim();
}

function addGuidedCodes(lines){
 lines.forEach(line=>{
  addProc(line.code,line.desc,line.wrvu||0,line.laterality||'',line.bi||0,line.approach,line.dx||[]);
 });
}

function renderGuidedCards(){
 const el=document.getElementById('guidedCards');
 if(!el)return;
 el.innerHTML=GUIDED_WORKFLOWS.map(w=>`<button class="proc" style="text-align:left" onclick="startGuidedFlow('${w.kind}')"><div class="proc-n">${w.title}</div><div class="proc-w" style="margin-top:6px;width:auto">${w.desc}</div></button>`).join('');
}

function startGuidedFlow(kind){
 guidedState={kind,step:0,data:{}};
 renderGuidedFlow();
}

function cancelGuidedFlow(){
 guidedState={kind:null,step:0,data:{}};
 const el=document.getElementById('guidedFlow');
 if(el){el.style.display='none';el.innerHTML='';}
}

function setGuidedValue(key,val){
 guidedState.data[key]=val;
 guidedState.step++;
 renderGuidedFlow();
}

function backGuidedFlow(){
 guidedState.step=Math.max(0,guidedState.step-1);
 renderGuidedFlow();
}

function finishGuidedFlow(lines){
 addGuidedCodes(lines);
 cancelGuidedFlow();
}

function renderGuidedFlow(){
 const el=document.getElementById('guidedFlow');
 if(!el)return;
 if(!guidedState.kind){el.style.display='none';el.innerHTML='';return;}
 el.style.display='block';
 const d=guidedState.data;
 const buttonRow=(items,key)=>`<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin-top:12px">${items.map(item=>`<button class="proc" style="text-align:left" onclick="setGuidedValue('${key}','${item.value}')"><div class="proc-n">${item.label}</div>${item.meta?`<div class="proc-w" style="margin-top:6px;width:auto">${item.meta}</div>`:''}</button>`).join('')}</div>`;
 if(guidedState.kind==='pd-catheter'){
  if(guidedState.step===0){el.innerHTML=`<div class="sec-h surg" style="border:0;padding:0;margin:0 0 8px">Peritoneal Dialysis Catheter</div><div>Placement or removal?</div>${buttonRow([{label:'Placement',value:'placement',meta:'49421'},{label:'Removal',value:'removal',meta:'49422'}],'action')}<div style="margin-top:12px"><button class="lat-cancel" onclick="cancelGuidedFlow()">cancel</button></div>`;return;}
  const isPlacement=d.action==='placement';
  finishGuidedFlow([{code:isPlacement?'49421':'49422',desc:isPlacement?'Peritoneal dialysis catheter placement, tunneled intraperitoneal':'Peritoneal dialysis catheter removal',wrvu:isPlacement?7.50:4.50,dx:['Z49.02','N18.6']}]);
  return;
 }
 if(guidedState.kind==='soft-tissue'){
  if(guidedState.step===0){el.innerHTML=`<div class="sec-h surg" style="border:0;padding:0;margin:0 0 8px">Soft Tissue Lesions / Lipoma / Cyst</div><div>What are you excising?</div>${buttonRow([{label:'Lipoma / soft tissue lesion',value:'lipoma'},{label:'Epidermal / benign skin cyst',value:'cyst'},{label:'Scalp lipoma / scalp benign lesion',value:'scalp'}],'family')}<div style="margin-top:12px"><button class="lat-cancel" onclick="cancelGuidedFlow()">cancel</button></div>`;return;}
  if(guidedState.step===1&&d.family==='lipoma'){el.innerHTML=`<div><strong>Location?</strong></div>${buttonRow([{label:'Back / flank',value:'back'},{label:'Abdominal wall',value:'abdomen'},{label:'Arm / elbow',value:'arm'},{label:'Leg / thigh / knee',value:'leg'}],'location')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if((guidedState.step===2&&d.family==='lipoma')||(guidedState.step===1&&d.family!=='lipoma')){
   el.innerHTML=`<div><strong>Size?</strong></div>${buttonRow([{label:'< 3 cm',value:'small'},{label:'3 cm or greater',value:'large'},{label:'3.1-4.0 cm benign lesion',value:'lesion-11404'}],'size')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;
   return;
  }
  if(d.family==='scalp'){
   finishGuidedFlow([{code:'11426',desc:'Excision scalp lipoma / benign scalp lesion 2.1-3.0 cm',wrvu:4.25,dx:['D17.0','L72.0']}]);
   return;
  }
  if(d.family==='cyst' || d.size==='lesion-11404'){
   finishGuidedFlow([{code:'11404',desc:'Excision epidermal inclusion cyst / benign trunk or extremity lesion 3.1-4.0 cm',wrvu:4.90,dx:['L72.0','L72.3','D23.5']}]);
   return;
  }
  const map={
   back:{small:['21931','Excision soft tissue lesion / lipoma, back or flank, subcutaneous <3 cm',5.40,['D17.1','L72.0']],large:['21932','Excision soft tissue lesion / lipoma, back or flank, subcutaneous 3 cm or greater',7.10,['D17.1','L72.0']]},
   abdomen:{small:['22902','Excision soft tissue lesion / lipoma, anterior abdominal wall, subcutaneous <3 cm',5.10,['D17.1','L72.0']],large:['22903','Excision soft tissue lesion / lipoma, anterior abdominal wall, subcutaneous 3 cm or greater',6.80,['D17.1','L72.0']]},
   arm:{small:['24071','Excision soft tissue lesion / lipoma, upper arm or elbow, subcutaneous <3 cm',5.20,['D17.21','L72.0']],large:['24073','Excision soft tissue lesion / lipoma, upper arm or elbow, subcutaneous 3 cm or greater',6.90,['D17.21','L72.0']]},
   leg:{small:['27327','Excision soft tissue lesion / lipoma, thigh or knee area, subcutaneous <3 cm',5.60,['D17.23','L72.0']],large:['27328','Excision soft tissue lesion / lipoma, thigh or knee area, subcutaneous 3 cm or greater',7.30,['D17.23','L72.0']]}
  };
  const chosen=map[d.location]?.[d.size];
  if(chosen){finishGuidedFlow([{code:chosen[0],desc:chosen[1],wrvu:chosen[2],dx:chosen[3]}]);return;}
 }
 if(guidedState.kind==='hiatal-hernia'){
  if(guidedState.step===0){el.innerHTML=`<div class="sec-h surg" style="border:0;padding:0;margin:0 0 8px">Hiatal / Paraesophageal Hernia</div><div>Repair type?</div>${buttonRow([{label:'Sliding hiatal hernia + fundoplication',value:'nissen',meta:'43280'},{label:'Paraesophageal repair',value:'para',meta:'43281'},{label:'Paraesophageal repair with mesh',value:'mesh',meta:'43282'},{label:'Open hiatal / paraesophageal repair',value:'open',meta:'43324'}],'type')}<div style="margin-top:12px"><button class="lat-cancel" onclick="cancelGuidedFlow()">cancel</button></div>`;return;}
  if(guidedState.step===1&&d.type!=='open'){el.innerHTML=`<div><strong>Approach performed robotically?</strong></div>${buttonRow([{label:'Yes, robotic/laparoscopic',value:'robotic'},{label:'Standard laparoscopic',value:'lap'}],'approach')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  const hiatalMap={
   nissen:['43280','Lap hiatal hernia repair / Nissen fundoplication',17.96,['K44.9','K21.9']],
   para:['43281','Lap paraesophageal hernia repair',16.25,['K44.9','K44.0']],
   mesh:['43282','Lap paraesophageal hernia repair with mesh',16.25,['K44.9','K44.0']],
   open:['43324','Open hiatal or paraesophageal hernia repair / fundoplasty',18.85,['K44.9','K44.0']]
  };
  const base=hiatalMap[d.type];
  if(!base){cancelGuidedFlow();return;}
  finishGuidedFlow([{code:base[0],desc:base[1],wrvu:base[2],approach:d.approach==='robotic'?'robotic':undefined,dx:base[3]}]);
  return;
 }
 if(guidedState.kind==='ent-sinus'){
  if(guidedState.step===0){el.innerHTML=`<div class="sec-h surg" style="border:0;padding:0;margin:0 0 8px">ENT Sinus Surgery</div><div>Primary sinus procedure?</div>${buttonRow([{label:'Maxillary antrostomy',value:'31256',meta:'31256'},{label:'Maxillary antrostomy with tissue removal',value:'31267',meta:'31267'},{label:'Frontal sinusotomy',value:'31276',meta:'31276'},{label:'Sphenoidotomy',value:'31287',meta:'31287'},{label:'Sphenoidotomy with tissue removal',value:'31288',meta:'31288'}],'primary')}<div style="margin-top:12px"><button class="lat-cancel" onclick="cancelGuidedFlow()">cancel</button></div>`;return;}
  if(guidedState.step===1){el.innerHTML=`<div><strong>Laterality?</strong></div>${buttonRow([{label:'Right',value:'RT'},{label:'Left',value:'LT'},{label:'Bilateral',value:'50'}],'side')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if(guidedState.step===2){el.innerHTML=`<div><strong>Add secondary sinus procedure?</strong></div>${buttonRow([{label:'None',value:'none'},{label:'Add 31267',value:'31267'},{label:'Add 31276',value:'31276'},{label:'Add 31287',value:'31287'},{label:'Add 31288',value:'31288'}],'secondary')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  const sinusMap={
   '31256':['Nasal/sinus endoscopy with maxillary antrostomy',5.04,['J32.0','J33.8']],
   '31267':['Nasal/sinus endoscopy with maxillary antrostomy; with removal of tissue from maxillary sinus',7.50,['J32.0','J33.0']],
   '31276':['Nasal/sinus endoscopy with frontal sinus exploration',6.80,['J32.1','J33.8']],
   '31287':['Nasal/sinus endoscopy with sphenoidotomy',5.90,['J32.3']],
   '31288':['Nasal/sinus endoscopy with sphenoidotomy with removal of tissue',7.10,['J32.3','J33.8']]
  };
  const primary=sinusMap[d.primary];
  if(!primary){cancelGuidedFlow();return;}
  const lines=[{code:d.primary,desc:primary[0],wrvu:primary[1],laterality:d.side,bi:1,dx:primary[2]}];
  if(d.secondary&&d.secondary!=='none'&&sinusMap[d.secondary]){
   const secondary=sinusMap[d.secondary];
   lines.push({code:d.secondary,desc:secondary[0],wrvu:secondary[1],laterality:d.side,bi:1,dx:secondary[2]});
  }
  finishGuidedFlow(lines);
  return;
 }
 function pushReleaseLine(lines,label,side,dx,mod59){
  const line={code:'15734',desc:`Myofascial flap, trunk - ${label}${side==='50'?', bilateral':`, ${side==='RT'?'right':'left'}`}`,wrvu:22.43,laterality:side,bi:1,dx};
  if(mod59)line.userMod='59';
  lines.push(line);
 }
 if(guidedState.kind==='ventral-hernia'){
  if(guidedState.step===0){el.innerHTML=`<div class="sec-h surg" style="border:0;padding:0;margin:0 0 8px">Ventral / Incisional Hernia</div><div>Initial or recurrent?</div>${buttonRow([{label:'Initial',value:'initial'},{label:'Recurrent',value:'recurrent'}],'timing')}<div style="margin-top:12px"><button class="lat-cancel" onclick="cancelGuidedFlow()">cancel</button></div>`;return;}
  if(guidedState.step===1){el.innerHTML=`<div><strong>Reducible or incarcerated/strangulated?</strong></div>${buttonRow([{label:'Reducible',value:'reducible'},{label:'Incarcerated / strangulated',value:'incarcerated'}],'severity')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if(guidedState.step===2){el.innerHTML=`<div><strong>Size?</strong></div>${buttonRow([{label:'<3 cm',value:'small'},{label:'3-10 cm',value:'medium'},{label:'>10 cm',value:'large'}],'size')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if(guidedState.step===3){el.innerHTML=`<div><strong>Approach?</strong></div>${buttonRow([{label:'Open',value:'open'},{label:'Laparoscopic / Robotic',value:'lap'}],'approach')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if(guidedState.step===4){el.innerHTML=`<div><strong>Was a myofascial release performed?</strong></div>${buttonRow([{label:'No',value:'no'},{label:'Yes',value:'yes'}],'releaseGate')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if(guidedState.step===5&&d.releaseGate==='yes'){el.innerHTML=`<div><strong>Was a rectus myofascial release (component separation) performed?</strong></div>${buttonRow([{label:'No',value:'no'},{label:'Yes',value:'yes'}],'rectusGate')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if(guidedState.step===6&&d.rectusGate==='yes'){el.innerHTML=`<div><strong>Select laterality for rectus myofascial release (CPT 15734):</strong></div>${buttonRow([{label:'Right',value:'RT'},{label:'Left',value:'LT'},{label:'Bilateral',value:'50'}],'rectusSide')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if((guidedState.step===6&&d.rectusGate!=='yes'&&d.releaseGate==='yes')||(guidedState.step===7&&d.releaseGate==='yes')){el.innerHTML=`<div><strong>Was a transversus abdominis release (posterior component separation) performed?</strong></div>${buttonRow([{label:'No',value:'no'},{label:'Yes',value:'yes'}],'tarGate')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if((guidedState.step===7&&d.tarGate==='yes'&&d.rectusGate!=='yes')||(guidedState.step===8&&d.tarGate==='yes')){el.innerHTML=`<div><strong>Select laterality for transversus abdominis release (CPT 15734):</strong></div>${buttonRow([{label:'Right',value:'RT'},{label:'Left',value:'LT'},{label:'Bilateral',value:'50'}],'tarSide')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  const baseMap={
   initial:{reducible:{small:{open:['49591',4.55,['K43.9','K43.2']],lap:['49652',8.33,['K43.9','K43.2']]},medium:{open:['49593',6.25,['K43.9','K43.2']],lap:['49653',10.95,['K43.9','K43.2']]},large:{open:['49595',9.61,['K43.9','K43.2']],lap:['49654',12.00,['K43.9','K43.2']]}},incarcerated:{small:{open:['49592',5.0,['K43.0','K43.1']],lap:['49652',8.33,['K43.0','K43.1']]},medium:{open:['49594',8.0,['K43.0','K43.1']],lap:['49653',10.95,['K43.0','K43.1']]},large:{open:['49596',18.20,['K43.0','K43.1']],lap:['49654',12.00,['K43.0','K43.1']]}}},
   recurrent:{reducible:{small:{open:['49613',7.0,['K43.2','K43.9']],lap:['49656',9.0,['K43.2','K43.9']]},medium:{open:['49615',9.0,['K43.2','K43.9']],lap:['49657',11.0,['K43.2','K43.9']]},large:{open:['49617',11.0,['K43.2','K43.9']],lap:['49657',11.0,['K43.2','K43.9']]}},incarcerated:{small:{open:['49614',8.0,['K43.0','K43.1']],lap:['49656',9.0,['K43.0','K43.1']]},medium:{open:['49616',10.0,['K43.0','K43.1']],lap:['49657',11.0,['K43.0','K43.1']]},large:{open:['49618',12.0,['K43.0','K43.1']],lap:['49657',11.0,['K43.0','K43.1']]}}}
  };
  const base=baseMap[d.timing]?.[d.severity]?.[d.size]?.[d.approach];
  if(!base){cancelGuidedFlow();return;}
  const lines=[{code:base[0],desc:`${d.approach==='lap'?'Lap / Robotic':'Open'} ${d.timing} ventral/incisional hernia ${d.size}`,wrvu:base[1],approach:d.approach==='lap'?'robotic':undefined,dx:base[2]}];
  if(d.releaseGate==='yes'&&d.rectusGate==='yes'&&d.rectusSide)pushReleaseLine(lines,'rectus myofascial release',d.rectusSide,base[2],false);
  if(d.releaseGate==='yes'&&d.tarGate==='yes'&&d.tarSide)pushReleaseLine(lines,'TAR',d.tarSide,base[2],d.rectusGate==='yes');
  finishGuidedFlow(lines);
  return;
 }
 if(guidedState.kind==='umbilical-hernia'){
  if(guidedState.step===0){el.innerHTML=`<div class="sec-h surg" style="border:0;padding:0;margin:0 0 8px">Umbilical Hernia</div><div>Age and complexity?</div>${buttonRow([{label:'Under 5, reducible',value:'49580',meta:'49580'},{label:'Under 5, incarcerated',value:'49582',meta:'49582'},{label:'Age 5+, reducible',value:'49585',meta:'49585'},{label:'Age 5+, incarcerated',value:'49587',meta:'49587'}],'baseCode')}<div style="margin-top:12px"><button class="lat-cancel" onclick="cancelGuidedFlow()">cancel</button></div>`;return;}
  if(guidedState.step===1){el.innerHTML=`<div><strong>Was a myofascial release performed?</strong></div>${buttonRow([{label:'No',value:'no'},{label:'Yes',value:'yes'}],'releaseGate')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if(guidedState.step===2&&d.releaseGate==='yes'){el.innerHTML=`<div><strong>Was a rectus myofascial release (component separation) performed?</strong></div>${buttonRow([{label:'No',value:'no'},{label:'Yes',value:'yes'}],'rectusGate')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if(guidedState.step===3&&d.rectusGate==='yes'){el.innerHTML=`<div><strong>Select laterality for rectus myofascial release (CPT 15734):</strong></div>${buttonRow([{label:'Right',value:'RT'},{label:'Left',value:'LT'},{label:'Bilateral',value:'50'}],'rectusSide')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if((guidedState.step===3&&d.rectusGate!=='yes'&&d.releaseGate==='yes')||(guidedState.step===4&&d.releaseGate==='yes')){el.innerHTML=`<div><strong>Was a transversus abdominis release (posterior component separation) performed?</strong></div>${buttonRow([{label:'No',value:'no'},{label:'Yes',value:'yes'}],'tarGate')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  if((guidedState.step===4&&d.tarGate==='yes'&&d.rectusGate!=='yes')||(guidedState.step===5&&d.tarGate==='yes')){el.innerHTML=`<div><strong>Select laterality for transversus abdominis release (CPT 15734):</strong></div>${buttonRow([{label:'Right',value:'RT'},{label:'Left',value:'LT'},{label:'Bilateral',value:'50'}],'tarSide')}<div style="margin-top:12px"><button class="lat-cancel" onclick="backGuidedFlow()">back</button></div>`;return;}
  const umbilicalMap={
   '49580':['49580','Repair umbilical hernia, younger than age 5 years; reducible',5.20,['K42.9']],
   '49582':['49582','Repair umbilical hernia, younger than age 5 years; incarcerated or strangulated',5.80,['K42.0']],
   '49585':['49585','Repair umbilical hernia, age 5 years or older; reducible',6.10,['K42.9']],
   '49587':['49587','Repair umbilical hernia, age 5 years or older; incarcerated or strangulated',6.60,['K42.0']]
  };
  const base=umbilicalMap[d.baseCode];
  if(!base){cancelGuidedFlow();return;}
  const lines=[{code:base[0],desc:base[1],wrvu:base[2],dx:base[3]}];
  if(d.releaseGate==='yes'&&d.rectusGate==='yes'&&d.rectusSide)pushReleaseLine(lines,'rectus myofascial release',d.rectusSide,base[3],false);
  if(d.releaseGate==='yes'&&d.tarGate==='yes'&&d.tarSide)pushReleaseLine(lines,'TAR',d.tarSide,base[3],d.rectusGate==='yes');
  finishGuidedFlow(lines);
  return;
 }
}

function buildSearchIndexFromSpecs(){
 return Object.entries(SPECS).flatMap(([specialty,procs],si)=>procs.map((p,pi)=>{
  const code=String(p[0]||'');
  const description=String(p[1]||'');
  const externalMeta=(searchState.codeMeta&&searchState.codeMeta[code])||null;
  const aliasMap={
   '15734':'myocutaneous flap myofascial flap muscle flap fasciocutaneous flap component separation retrorectus release transversus abdominis release tar abdominal wall reconstruction',
   '31256':'maxillary antrostomy fess sinus surgery maxillary sinusotomy',
   '31267':'maxillary antrostomy tissue removal fess polyp sinus surgery',
   '31276':'frontal sinusotomy draf frontal sinus surgery',
   '31287':'sphenoidotomy sphenoid sinus surgery',
   '31288':'sphenoidotomy tissue removal sphenoid sinus surgery',
   '43280':'hiatal hiatal hernia fundoplication nissen toupet',
   '43281':'paraesophageal paraesophageal hernia repair laparoscopic hiatal',
   '43282':'paraesophageal paraesophageal hernia repair mesh laparoscopic hiatal',
   '43324':'open hiatal paraesophageal hernia repair fundoplasty nissen belsey hill',
   '49568':'ventral hernia mesh add on implantation abdominal wall reinforcement'
  };
  const aliases=aliasMap[code]||'';
  return {
   code,
   description,
   wrvu:Number(p[2]||0),
   bi:(p[3]===0||p[3]===1||p[3]===2)?p[3]:0,
   specialty,
   si,
   pi,
   rvuStatus:String(externalMeta?.rvu_status||''),
   rvuLabel:String(externalMeta?.rvu_display_label||''),
   rvuYear:String(externalMeta?.rvu_year||CMS_RVU_YEAR),
   rvuSourceFile:String(externalMeta?.rvu_source_file||CMS_RVU_SOURCE_FILE),
   haystack:normalizeSearchValue(`${specialty} ${code} ${description} ${aliases}`)
  };
 }));
}

async function loadCptSearchIndex(){
 try{
  const res=await fetch('cpt_database.json');
  if(!res.ok)throw new Error(`HTTP ${res.status}`);
  const data=await res.json();
  updateCmsBadges(data);
  const entries=(data&&typeof data==='object'&&!Array.isArray(data))?Object.values(data):Array.isArray(data?.codes)?data.codes:[];
  searchState.codeMeta=entries.reduce((acc,entry)=>{
   if(entry&&entry.code)acc[String(entry.code)]=entry;
   return acc;
  },{});
  const specIndex=buildSearchIndexFromSpecs();
  const seen=new Set(specIndex.map(item=>item.code));
  const externalIndex=entries.slice(0,4000).map(entry=>({
   code:String(entry.code||''),
   description:String(entry.description||''),
   wrvu:Number(entry.work_rvu||entry.total_rvu||0),
   bi:0,
   specialty:'Database',
   si:null,
   pi:null,
   rvuStatus:String(entry.rvu_status||''),
   rvuLabel:String(entry.rvu_display_label||''),
   rvuYear:String(entry.rvu_year||CMS_RVU_YEAR),
   rvuSourceFile:String(entry.rvu_source_file||CMS_RVU_SOURCE_FILE),
   haystack:normalizeSearchValue(`${entry.code||''} ${entry.description||''}`)
  })).filter(item=>item.code&&!seen.has(item.code));
  searchState.cptSearchIndex=[...specIndex,...externalIndex];
 }catch(err){
  console.warn('Search index fallback to on-page data',err);
  searchState.cptSearchIndex=buildSearchIndexFromSpecs();
 }
}

function updateCmsBadges(data){
 const sample=(data&&typeof data==='object'&&!Array.isArray(data))?Object.values(data).find(Boolean):null;
 const year=sample?.rvu_year||CMS_RVU_YEAR;
 const source=sample?.rvu_source_file||CMS_RVU_SOURCE_FILE;
 const release=CMS_RVU_RELEASE;
 const yearBadge=document.getElementById('cmsYearBadge');
 const sourceBadge=document.getElementById('cmsSourceBadge');
 const railSource=document.getElementById('railCmsSource');
 const cfBadge=document.getElementById('cfBadge');
 if(yearBadge)yearBadge.textContent=`CMS ${year}`;
 if(sourceBadge)sourceBadge.textContent=`${release} · ${source}`;
 if(railSource)railSource.textContent=`CMS ${year} · ${release} · ${source}`;
 if(cfBadge)cfBadge.textContent=`CF ${CF.toFixed(4)}`;
}

function scoreSearchResult(item,query){
 const raw=String(query||'').trim();
 const q=normalizeSearchValue(raw);
 if(!q)return -1;
 const desc=normalizeSearchValue(item.description);
 const words=q.split(' ').filter(Boolean);
 if(item.code===raw)return 100;
 if(item.code.startsWith(raw))return 80;
 if(desc===q)return 76;
 if(desc.startsWith(q))return 74;
 if(desc.includes(` ${q} `)||desc.startsWith(`${q} `)||desc.endsWith(` ${q}`))return 72;
 if(words.length&&words.every(word=>desc.includes(` ${word} `)||desc.startsWith(`${word} `)||desc.endsWith(` ${word}`)))return 71;
 if(desc.includes(q))return 70;
 if(item.haystack.includes(q))return 52;
 if(words.length&&words.every(word=>desc.includes(word)))return 46;
 if(words.length&&words.every(word=>item.haystack.includes(word)))return 40;
 return -1;
}

function filterSpecialtyCards(){
 const q=searchState.specialtyFilter;
 document.querySelectorAll('.spec').forEach((s,i)=>{
  if(!q){s.style.display='';return}
  const name=Object.keys(SPECS)[i].toLowerCase();
  const procs=SPECS[Object.keys(SPECS)[i]];
  const match=name.includes(q)||procs.some(p=>`${p[0]||''} ${p[1]||''}`.toLowerCase().includes(q));
  s.style.display=match?'':'none';
  if(match&&q.length>1)s.classList.add('open');
 });
}

function renderAutocompleteResults(){
 const box=document.getElementById('autocompleteResults');
 const results=searchState.searchResults;
 if(!searchState.searchQuery||!results.length){
  if(searchState.searchQuery&&searchState.searchQuery.length>=2){
   box.innerHTML='<div class="autocomplete-empty">No CPT matches. Try procedure name, CPT code, or specialty.</div>';
   box.classList.add('show');
   return;
  }
  box.innerHTML='';
  box.classList.remove('show');
  return;
 }
 box.innerHTML=`<div class="autocomplete-group">${results.map((item,index)=>`<div class="autocomplete-item ${index===searchState.activeResultIndex?'active':''}" onclick="selectAutocompleteResult(${index})"><div class="autocomplete-code">${item.code||'search'}</div><div class="autocomplete-main"><div class="autocomplete-title">${item.description||item.specialty}</div><div class="autocomplete-meta"><span>${item.specialty}</span><span>wRVU ${Number(item.wrvu||0).toFixed(2)}</span></div></div><div class="autocomplete-action">add</div></div>`).join('')}</div>`;
 box.classList.add('show');
}

function applyTypeaheadSuggestion(rawQuery){
 const input=document.getElementById('q');
 if(searchState.suppressTypeahead)return;
 if(document.activeElement!==input)return;
 const query=String(rawQuery||'');
 const top=searchState.searchResults[0];
 if(query.trim().length<2||!top)return;
 const suggestion=`${top.code} ${top.description}`.trim();
 const qNorm=normalizeSearchValue(query);
 const sNorm=normalizeSearchValue(suggestion);
 if(!qNorm||!sNorm.startsWith(qNorm))return;
 if(suggestion.toLowerCase()===query.toLowerCase())return;
 input.value=suggestion;
 input.setSelectionRange(query.length,suggestion.length);
}

function filterSearchExperience(query){
 searchState.searchQuery=query;
 searchState.specialtyFilter=query.toLowerCase().trim();
 searchState.activeResultIndex=-1;
 filterSpecialtyCards();
 if(searchState.searchQuery.trim().length<2){
  searchState.searchResults=[];
  renderAutocompleteResults();
  return;
 }
 const ranked=searchState.cptSearchIndex.map(item=>({item,score:scoreSearchResult(item,query)})).filter(entry=>entry.score>=0).sort((a,b)=>b.score-a.score||a.item.description.length-b.item.description.length).slice(0,12).map(entry=>entry.item);
 searchState.searchResults=ranked;
 renderAutocompleteResults();
 applyTypeaheadSuggestion(query);
}

const HERNIA_WIZARD_OPTIONS={
 '49652':[
  {label:'<3 cm',code:'49652',desc:'Lap / Robotic anterior abd hernia <3cm',wrvu:8.33},
  {label:'3-10 cm',code:'49653',desc:'Lap / Robotic anterior abd hernia 3-10cm',wrvu:10.95},
  {label:'>10 cm',code:'49654',desc:'Lap / Robotic anterior abd hernia >10cm',wrvu:12.00}
 ],
 '49653':[
  {label:'<3 cm',code:'49652',desc:'Lap / Robotic anterior abd hernia <3cm',wrvu:8.33},
  {label:'3-10 cm',code:'49653',desc:'Lap / Robotic anterior abd hernia 3-10cm',wrvu:10.95},
  {label:'>10 cm',code:'49654',desc:'Lap / Robotic anterior abd hernia >10cm',wrvu:12.00}
 ],
 '49654':[
  {label:'<3 cm',code:'49652',desc:'Lap / Robotic anterior abd hernia <3cm',wrvu:8.33},
  {label:'3-10 cm',code:'49653',desc:'Lap / Robotic anterior abd hernia 3-10cm',wrvu:10.95},
  {label:'>10 cm',code:'49654',desc:'Lap / Robotic anterior abd hernia >10cm',wrvu:12.00}
 ]
};

function promptHerniaComponentSeparation(base){
 const releaseType=window.prompt(`Component separation performed for ${base.label}?\n\nType one:\n- none\n- rectus left\n- rectus right\n- rectus bilateral\n- tar left\n- tar right\n- tar bilateral`,`none`);
 if(releaseType===null)return;
 addProc(base.code,base.desc,base.wrvu,'',0,'robotic');
 const normalized=String(releaseType||'').trim().toLowerCase();
 if(!normalized||normalized==='none')return;
 const isTar=normalized.includes('tar');
 const descBase=isTar?'Myofascial flap, trunk - TAR':'Myofascial flap, trunk - rectus myofascial release';
 if(normalized.includes('bilateral')){
  addProc('15734',`${descBase}, bilateral`,22.43,'50',1);
  return;
 }
 if(normalized.includes('right')){addProc('15734',`${descBase}, right`,22.43,'RT',1);return}
 if(normalized.includes('left')){addProc('15734',`${descBase}, left`,22.43,'LT',1);return}
}

function promptLapRoboticAnteriorHernia(item){
 const opts=HERNIA_WIZARD_OPTIONS[item.code]||HERNIA_WIZARD_OPTIONS['49653'];
 const picked=window.prompt(`Select anterior abdominal wall hernia size:\n\n1 = <3 cm\n2 = 3-10 cm\n3 = >10 cm`,`2`);
 if(picked===null)return true;
 const chosen=opts[{ '1':0,'2':1,'3':2 }[String(picked).trim()] ?? 1];
 promptHerniaComponentSeparation({label:chosen.label,code:chosen.code,desc:chosen.desc,wrvu:chosen.wrvu});
 return true;
}

function shouldPromptLaterality({cpt,desc,bi}){
 const normalizedDesc=String(desc||'').toLowerCase();
 if(bi!==1)return false;
 if(/bilateral|inherently bilateral/.test(normalizedDesc))return false;
 if(/^15734$/.test(String(cpt||'')))return false;
 return true;
}

function promptUnilateralBilateralCase({cpt,desc,wrvu,bi,approach,dx}){
 if(!shouldPromptLaterality({cpt,desc,bi}))return false;
 const normalizedDesc=String(desc||'').toLowerCase();
 const promptFamily = normalizedDesc.includes('hernia') ? 'repair' : 'procedure';
 const sideChoice=window.prompt(`Is this ${promptFamily} unilateral or bilateral?\n\nType one:\n- unilateral\n- bilateral`,`unilateral`);
 if(sideChoice===null)return true;
 const normalizedChoice=String(sideChoice).trim().toLowerCase();
 if(normalizedChoice.startsWith('b')){
  addProc(cpt,`${desc} (bilateral)`,wrvu,'50',1,approach,dx);
  return true;
 }
 const lateralityPrompt=window.prompt(`Which side?\n\nType one:\n- right\n- left`,`right`);
 if(lateralityPrompt===null)return true;
 const normalizedLaterality=String(lateralityPrompt).trim().toLowerCase();
 const laterality=normalizedLaterality.startsWith('l')?'LT':'RT';
 addProc(cpt,`${desc} (${laterality==='RT'?'right':'left'})`,wrvu,laterality,1,approach,dx);
 return true;
}

function addAutocompleteResultToCase(item){
 const meta={rvuStatus:item.rvuStatus,rvuLabel:item.rvuLabel,rvuYear:item.rvuYear,rvuSourceFile:item.rvuSourceFile};
 if(['49652','49653','49654'].includes(String(item.code||''))&&/anterior abd hernia|ventral hernia/i.test(String(item.description||''))){
  if(promptLapRoboticAnteriorHernia(item))return;
 }
 if(item.si!==null&&item.pi!==null){
  const p=SPECS[item.specialty][item.pi];
  const [cpt,desc,w,bi]=p;
  if(['49652','49653','49654'].includes(String(cpt||''))&&/anterior abd hernia|ventral hernia/i.test(String(desc||''))){
   if(promptLapRoboticAnteriorHernia({code:cpt,description:desc,wrvu:w}))return;
  }
  if(promptUnilateralBilateralCase({cpt,desc,wrvu:w,bi,approach:undefined,dx:undefined}))return;
  if((bi===1||bi===2)&&bi!==2){
   addProc(cpt,desc,w,'',1,undefined,undefined,meta);
  }else{
   addProc(cpt,desc,w,'',bi||0,undefined,undefined,meta);
  }
  return;
 }
 if(promptUnilateralBilateralCase({cpt:item.code,desc:item.description,wrvu:item.wrvu||0,bi:item.bi||0,approach:item.approach,dx:item.dx||[]}))return;
 addProc(item.code,item.description,item.wrvu||0,'',item.bi||0,undefined,undefined,meta);
}

function selectAutocompleteResult(index){
 const item=searchState.searchResults[index];
 if(!item)return;
 addAutocompleteResultToCase(item);
 document.getElementById('q').value=`${item.code} ${item.description}`.trim();
 searchState.searchResults=[];
 searchState.activeResultIndex=-1;
 renderAutocompleteResults();
}

document.getElementById('q').addEventListener('input',e=>{
 searchState.suppressTypeahead=false;
 filterSearchExperience(e.target.value);
});

document.getElementById('q').addEventListener('keydown',e=>{
 const input=e.currentTarget;
 const max=searchState.searchResults.length-1;
 if(e.key==='Tab'){
  if(searchState.searchResults.length&&input.selectionStart!==input.selectionEnd){
   e.preventDefault();
   const pos=input.value.length;
   input.setSelectionRange(pos,pos);
   searchState.searchQuery=input.value;
  }
  return;
 }
 if(e.key==='ArrowRight'){
  if(searchState.searchResults.length&&input.selectionStart!==input.selectionEnd&&input.selectionEnd===input.value.length){
   e.preventDefault();
   const pos=input.value.length;
   input.setSelectionRange(pos,pos);
   searchState.searchQuery=input.value;
  }
  return;
 }
 if(['Backspace','Delete','ArrowLeft','Home','End'].includes(e.key))searchState.suppressTypeahead=true;
 if(e.key==='ArrowDown'&&max>=0){e.preventDefault();searchState.activeResultIndex=Math.min(searchState.activeResultIndex+1,max);renderAutocompleteResults();return}
 if(e.key==='ArrowUp'&&max>=0){e.preventDefault();searchState.activeResultIndex=Math.max(searchState.activeResultIndex-1,0);renderAutocompleteResults();return}
 if(e.key==='Enter'&&searchState.activeResultIndex>=0){e.preventDefault();selectAutocompleteResult(searchState.activeResultIndex);return}
 if(e.key==='Enter'&&searchState.searchResults.length&&input.selectionStart!==input.selectionEnd){e.preventDefault();selectAutocompleteResult(0);return}
 if(e.key==='Escape'){searchState.searchResults=[];searchState.activeResultIndex=-1;renderAutocompleteResults();}
});

document.getElementById('q').addEventListener('click',e=>{
 if(e.currentTarget.selectionStart===e.currentTarget.selectionEnd)searchState.suppressTypeahead=false;
});

document.addEventListener('click',e=>{
 if(!e.target.closest('.search-wrap')){
  searchState.activeResultIndex=-1;
  searchState.searchResults=[];
  renderAutocompleteResults();
 }
});

document.addEventListener('keydown',e=>{if((e.metaKey||e.ctrlKey)&&e.key.toLowerCase()==='k'){e.preventDefault();document.getElementById('q').focus()}});

renderSpecs();
renderGuidedCards();
loadCptSearchIndex();
</script><style>.site-footer{margin-top:36px;background:#0B1220;color:#D7DFEA}.site-footer-inner{max-width:1200px;margin:0 auto;padding:32px 40px}.site-footer-brand{font-size:14px;font-weight:700;color:#fff}.site-footer-copy{margin-top:10px;font-size:14px;line-height:1.7;color:#D7DFEA;max-width:980px}.site-footer-copy strong{color:#fff}.site-footer-nav{display:flex;flex-wrap:wrap;gap:14px;margin-top:16px}.site-footer-nav a{color:#8ec5ff;text-decoration:none;font-size:14px}@media(max-width:1000px){.site-footer-inner{padding:24px 20px}}</style><footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-brand">FreeCPTCodeFinder.com</div>
    <p class="site-footer-copy">FreeCPTCodeFinder.com is an independent educational reference for CPT coding, RVUs, reimbursement, and documentation. Educational information only. Always verify coding, coverage, reimbursement, and compliance decisions with current AMA, CMS, payer, and regulatory guidance.</p>
