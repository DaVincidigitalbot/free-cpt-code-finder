      <a href="/terms.html">Terms of Use</a>
      <a href="/legal.html">Legal / CPT Notice</a>
      <a href="/editorial-policy.html">Editorial Policy</a>
      <a href="/sitemap.xml">Sitemap</a>
      <a href="/blog/">Blog / Guides</a>
      <a href="/codes/">CPT Code Search</a>
    </nav>
  </div>
</footer>
